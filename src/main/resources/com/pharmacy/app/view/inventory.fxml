<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pharmacy.app.controller.InventoryController">
    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="10" right="15" bottom="8" left="15"/>
            </padding>
            <HBox>
                <Button text="&#8592; Back" onAction="#handleBack"/>
            </HBox>
            <Label text="&#128138; Inventory" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Search by name, generic name, or barcode..." prefWidth="350"/>
                <Button text="Search" onAction="#handleSearch"/>
                <Button text="Clear" onAction="#handleClear"/>
                <Button text="+ Add Medicine" onAction="#handleAddMedicine" style="-fx-font-weight: bold;"/>
                <Button text="+ Add Stock Batch" onAction="#handleAddBatch"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="medicineTable">
            <columns>
                <TableColumn fx:id="nameCol" text="Name" prefWidth="150"/>
                <TableColumn fx:id="genericCol" text="Generic Name" prefWidth="130"/>
                <TableColumn fx:id="categoryCol" text="Category" prefWidth="100"/>
                <TableColumn fx:id="manufacturerCol" text="Manufacturer" prefWidth="120"/>
                <TableColumn fx:id="priceCol" text="Unit Price" prefWidth="80"/>
                <TableColumn fx:id="taxCol" text="Tax %" prefWidth="60"/>
                <TableColumn fx:id="stockCol" text="Total Stock" prefWidth="90"/>
                <TableColumn fx:id="controlledCol" text="Controlled" prefWidth="80"/>
                <TableColumn fx:id="barcodeCol" text="Barcode" prefWidth="100"/>
            </columns>
        </TableView>
    </center>
</BorderPane>