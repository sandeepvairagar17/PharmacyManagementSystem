<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmacy.app.controller.AddBatchController">
    <padding>
        <Insets top="15" right="40" bottom="30" left="40"/>
    </padding>

    <HBox>
        <Button text="&#8592; Back" onAction="#handleCancel"/>
    </HBox>

    <HBox spacing="30">
        <VBox alignment="CENTER" spacing="10" prefWidth="200" style="-fx-background-color: #f7f2ee; -fx-background-radius: 14;">
            <padding><Insets top="40" bottom="40"/></padding>
            <Label text="&#128230;" style="-fx-font-size: 72px;"/>
            <Label text="Record new stock received from your supplier, with expiry tracking" style="-fx-text-fill: #566; -fx-font-size: 12px;" wrapText="true" textAlignment="CENTER" maxWidth="160"/>
        </VBox>

        <VBox spacing="10">
            <Label fx:id="titleLabel" text="Add Stock Batch" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

            <GridPane hgap="10" vgap="10">
                <Label text="Batch Number*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="batchNoField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="220"/>

                <Label text="Expiry Date*" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <DatePicker fx:id="expiryDatePicker" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label fx:id="quantityLabel" text="Quantity Received (in packs)*" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="quantityField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Cost Price (per pack, from supplier)" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="costPriceField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
            </GridPane>

            <Label fx:id="conversionLabel" style="-fx-text-fill: #666; -fx-font-size: 12px;"/>

            <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

            <HBox spacing="10">
                <Button text="Save" onAction="#handleSave" style="-fx-font-weight: bold;"/>
                <Button text="Cancel" onAction="#handleCancel"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>