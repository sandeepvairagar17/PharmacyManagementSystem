<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pharmacy.app.controller.BillingController">
    <top>
        <VBox spacing="8">
            <padding>
                <Insets top="10" right="15" bottom="8" left="15"/>
            </padding>
            <HBox>
                <Button text="&#8592; Back" onAction="#handleBack"/>
            </HBox>
            <Label text="&#128176; Billing / New Sale" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="10">
                <TextField fx:id="searchField" promptText="Type medicine name or scan barcode..." prefWidth="350"/>
            </HBox>
            <ListView fx:id="suggestionsList" prefHeight="110" visible="false" managed="false"/>
        </VBox>
    </top>

    <center>
        <TableView fx:id="cartTable">
            <columns>
                <TableColumn fx:id="cartNameCol" text="Medicine" prefWidth="200"/>
                <TableColumn fx:id="cartQtyCol" text="Qty" prefWidth="80"/>
                <TableColumn fx:id="cartPriceCol" text="Unit Price" prefWidth="90"/>
                <TableColumn fx:id="cartTaxCol" text="Tax %" prefWidth="70"/>
                <TableColumn fx:id="cartLineTotalCol" text="Line Total" prefWidth="100"/>
                <TableColumn fx:id="cartRemoveCol" text="" prefWidth="80"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <VBox spacing="8">
            <padding>
                <Insets top="10" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="20" alignment="CENTER_RIGHT">
                <Label text="Discount (%):"/>
                <TextField fx:id="discountField" text="0" prefWidth="70"/>
                <Label text="Payment Mode:"/>
                <ComboBox fx:id="paymentModeBox" prefWidth="120"/>
            </HBox>
            <HBox spacing="20" alignment="CENTER_RIGHT">
                <Label fx:id="subtotalLabel" text="Subtotal: 0.00" style="-fx-font-size: 14px;"/>
                <Label fx:id="taxLabel" text="Tax: 0.00" style="-fx-font-size: 14px;"/>
                <Label fx:id="discountLabel" text="Discount: 0.00" style="-fx-font-size: 14px;"/>
                <Label fx:id="totalLabel" text="Total: 0.00" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>
                <Button text="Checkout" onAction="#handleCheckout" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-pref-width: 150px;"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>