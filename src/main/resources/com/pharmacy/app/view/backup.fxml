<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmacy.app.controller.BackupController">
    <padding>
        <Insets top="15" right="30" bottom="20" left="30"/>
    </padding>

    <HBox>
        <Button text="&#8592; Back" onAction="#handleBack"/>
    </HBox>

    <Label text="&#128190; Backup &amp; Restore" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    <Label text="Backups are saved in a 'backups' folder next to the application." style="-fx-text-fill: #666;"/>

    <HBox spacing="10">
        <Button text="Backup Now" onAction="#handleBackupNow" style="-fx-font-weight: bold;"/>
        <Button text="Refresh List" onAction="#handleRefresh"/>
        <Button text="Restore Selected Backup" onAction="#handleRestore" style="-fx-text-fill: #a00;"/>
    </HBox>

    <Label fx:id="statusLabel" style="-fx-text-fill: green;"/>

    <Label text="Available Backups:" style="-fx-font-weight: bold;"/>
    <ListView fx:id="backupListView" prefHeight="300"/>

</VBox>