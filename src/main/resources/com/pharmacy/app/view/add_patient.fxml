<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pharmacy.app.controller.AddPatientController">
    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <Label text="Add New Patient" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Name*" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="250"/>

        <Label text="Phone" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="phoneField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Date of Birth (YYYY-MM-DD)" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="dobField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Allergies" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextArea fx:id="allergiesField" GridPane.rowIndex="3" GridPane.columnIndex="1" prefRowCount="2"/>

        <Label text="Notes" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextArea fx:id="notesField" GridPane.rowIndex="4" GridPane.columnIndex="1" prefRowCount="2"/>
    </GridPane>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <HBox spacing="10">
        <Button text="Save" onAction="#handleSave" style="-fx-font-weight: bold;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>
</VBox>